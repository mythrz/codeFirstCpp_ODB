{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 10,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "clang-debug",
            "displayName": "Clang Debug",
            "description": "Configure using Clang compiler for debugging",
            "generator": "Ninja Multi-Config",
            "binaryDir": "${sourceDir}/build/linux",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "clang-debug",
            "displayName": "Clang Debug",
            "description": "Build using Clang compiler for debugging",
            "configurePreset": "clang-debug",
            "configuration": "Debug"
        }
    ]
}